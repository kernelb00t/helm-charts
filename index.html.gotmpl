<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Helm Charts</title>
    <style>
        :root {
            --bg-main: #09090b;
            --bg-card: #18181b;
            --border-color: #27272a;
            --text-main: #fafafa;
            --text-muted: #a1a1aa;
            --accent-primary: #7e22ce;
            --code-bg: #18181b;
            --radius-md: 8px;
            --radius-lg: 12px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg-main);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .bg-glow {
            position: fixed;
            top: -50%;
            left: 50%;
            transform: translateX(-50%);
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, #7e22ce33 0%, transparent 70%);
            z-index: -1;
            opacity: 0.3;
            pointer-events: none;
        }

        header {
            padding: 4rem 2rem;
            text-align: center;
        }

        h1 {
            font-size: 3.5rem;
            font-weight: 700;
            letter-spacing: -0.05em;
            margin-bottom: 1rem;
            background: linear-gradient(to right, #fff, #a1a1aa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        p.subtitle {
            font-size: 1.25rem;
            color: var(--text-muted);
            max-width: 600px;
            margin: 0 auto;
        }

        main {
            max-width: 900px;
            width: 100%;
            margin: 0 auto;
            padding: 2rem;
            flex: 1;
        }

        .card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .card:hover {
            border-color: #3f3f46;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }

        .card h2 {
            font-size: 1.5rem;
            margin-bottom: 1.5rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .step {
            margin-bottom: 1.5rem;
        }

        .step-title {
            font-weight: 500;
            margin-bottom: 0.5rem;
            color: var(--text-main);
            display: flex;
            align-items: center;
        }

        .step-number {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
            background: var(--accent-primary);
            color: white;
            border-radius: 50%;
            font-size: 0.875rem;
            font-weight: 700;
            margin-right: 0.75rem;
        }

        .code-block {
            background: var(--code-bg);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: 1rem 1.25rem;
            font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
            font-size: 0.95rem;
            color: #e4e4e7;
            position: relative;
            overflow-x: auto;
            white-space: pre-wrap;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .code-content {
            margin-right: 1rem;
        }

        .copy-btn {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-muted);
            padding: 0.25rem 0.5rem;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.75rem;
            transition: all 0.2s;
            flex-shrink: 0;
        }

        .copy-btn:hover {
            background: #27272a;
            color: white;
            border-color: #52525b;
        }

        footer {
            text-align: center;
            padding: 2rem;
            color: var(--text-muted);
            font-size: 0.875rem;
            border-top: 1px solid var(--border-color);
            margin-top: auto;
        }

        a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.2s;
        }

        a:hover {
            color: var(--text-main);
            text-decoration: underline;
        }

        .badge-container {
            display: flex;
            gap: 1rem;
            justify-content: center;
            margin-top: 2rem;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 0.25rem 0.75rem;
            background: #27272a;
            border-radius: 999px;
            font-size: 0.875rem;
            color: #e4e4e7;
            border: 1px solid transparent;
        }

        .badge img {
            margin-right: 0.5rem;
            height: 16px;
        }
    </style>
</head>

<body>

    <div class="bg-glow"></div>

    <header>
        <h1>Helm Charts</h1>
        <p class="subtitle">Deploy applications to your Kubernetes cluster easily.</p>
        <div class="badge-container">
            <a href="{{ getenv "GIT_REPO_URL" }}" target="_blank" class="badge">
{{ if eq (getenv "GIT_PLATFORM" "gitea") "github" }}
                <svg height="16" viewBox="0 0 16 16" version="1.1" width="16" fill="currentColor" style="margin-right: 6px;">
                    <path fill-rule="evenodd"
                        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z">
                    </path>
                </svg>
                GitHub
{{ else }}
                <svg height="16" viewBox="0 0 24 24" version="1.1" width="16" fill="currentColor" style="margin-right: 6px;">
                    <path d="M4.209 4.603c-.247 0-.525.02-.84.088-.333.07-1.28.283-2.054 1.027C-.403 7.25.035 9.685.089 10.052c.065.446.263 1.687 1.21 2.768 1.749 2.141 5.513 2.092 5.513 2.092s.462 1.103 1.168 2.119c.955 1.263 1.936 2.248 2.89 2.367 2.406 0 7.212-.004 7.212-.004s.458.004 1.08-.394c.535-.324 1.013-.893 1.013-.893s.492-.527 1.18-1.73c.21-.37.385-.729.538-1.068 0 0 2.107-4.471 2.107-8.823-.042-1.318-.367-1.55-.443-1.627-.156-.156-.366-.153-.366-.153s-4.475.252-6.792.306c-.508.011-1.012.023-1.512.027v4.474l-.634-.301c0-1.39-.004-4.17-.004-4.17-1.107.016-3.405-.084-3.405-.084s-5.399-.27-5.987-.324c-.187-.011-.401-.032-.648-.032zm.354 1.832h.111s.271 2.269.6 3.597C5.549 11.147 6.22 13 6.22 13s-.996-.119-1.641-.348c-.99-.324-1.409-.714-1.409-.714s-.73-.511-1.096-1.52C1.444 8.73 2.021 7.7 2.021 7.7s.32-.859 1.47-1.145c.395-.106.863-.12 1.072-.12zm8.33 2.554c.26.003.509.127.509.127l.868.422-.529 1.075a.686.686 0 0 0-.614.359.685.685 0 0 0 .072.756l-.939 1.924a.69.69 0 0 0-.66.527.687.687 0 0 0 .347.763.686.686 0 0 0 .867-.206.688.688 0 0 0-.069-.882l.916-1.874a.667.667 0 0 0 .237-.02.657.657 0 0 0 .271-.137 8.826 8.826 0 0 1 1.016.512.761.761 0 0 1 .286.282c.073.21-.073.569-.073.569-.087.29-.702 1.55-.702 1.55a.692.692 0 0 0-.676.477.681.681 0 1 0 1.157-.252c.073-.141.141-.282.214-.431.19-.397.515-1.16.515-1.16.035-.066.218-.394.103-.814-.095-.435-.48-.638-.48-.638-.467-.301-1.116-.58-1.116-.58s0-.156-.042-.27a.688.688 0 0 0-.148-.241l.516-1.062 2.89 1.401s.48.218.583.619c.073.282-.019.534-.069.657-.24.587-2.1 4.317-2.1 4.317s-.232.554-.748.588a1.065 1.065 0 0 1-.393-.045l-.202-.08-4.31-2.1s-.417-.218-.49-.596c-.083-.31.104-.691.104-.691l2.073-4.272s.183-.37.466-.497a.855.855 0 0 1 .35-.077z"/>
                </svg>
                Gitea
{{ end }}
            </a>
        </div>
    </header>

    <main>
        <div class="card">
            <h2>Setup</h2>
            <div class="step">
                <div class="step-title"><span class="step-number">1</span>Add the repository</div>
                <div class="code-block">
                    <code id="repo-add-cmd" class="code-content">helm repo add dev-charts {{ .Env.REPO_URL }}
helm repo update</code>
                    <button class="copy-btn" onclick="copyToClipboard(this)">Copy</button>
                </div>
            </div>
        </div>

        <div class="card">
            <h2>Available Charts</h2>
{{ range (datasource "charts").charts }}
            <div class="step">
                <div class="step-title">{{ .name }}</div>
                <p style="color: var(--text-muted); margin-bottom: 0.75rem; font-size: 0.95rem;">{{ .description }}</p>
                <div class="code-block">
                    <code class="code-content">helm install {{ .name }} dev-charts/{{ .name }} --create-namespace --namespace {{ .name }}</code>
                    <button class="copy-btn" onclick="copyToClipboard(this)">Copy</button>
                </div>
            </div>
{{ end }}
        </div>

        <div class="card">
            <h2>Prerequisites</h2>
            <ul style="padding-left: 1.5rem; color: var(--text-muted); list-style-type: disc;">
                <li style="margin-bottom: 0.5rem;">Kubernetes 1.23+</li>
                <li style="margin-bottom: 0.5rem;">Helm 3.0+</li>
                <li style="margin-bottom: 0.5rem;">Dependencies (check individual charts)</li>
            </ul>
        </div>
    </main>

    <script>
        function copyToClipboard(button) {
            const codeContent = button.previousElementSibling;
            const text = codeContent.innerText;

            navigator.clipboard.writeText(text).then(() => {
                const originalText = button.innerText;
                button.innerText = 'Copied!';
                button.style.borderColor = '#7e22ce';
                button.style.color = '#fff';

                setTimeout(() => {
                    button.innerText = originalText;
                    button.style.borderColor = '';
                    button.style.color = '';
                }, 2000);
            });
        }
    </script>
</body>

</html>
