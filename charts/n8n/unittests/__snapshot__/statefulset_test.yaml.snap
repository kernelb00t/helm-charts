  13: |
    apiVersion: apps/v1
    kind: StatefulSet
    metadata:
      labels:
        app.kubernetes.io/component: main
        app.kubernetes.io/instance: n8n
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: n8n
        app.kubernetes.io/version: 1.0.0
        helm.sh/chart: n8n-1.0.0
      name: n8n
    spec:
      replicas: 2
      selector:
        matchLabels:
          app.kubernetes.io/component: main
          app.kubernetes.io/instance: n8n
          app.kubernetes.io/name: n8n
      serviceName: n8n-headless
      template:
        metadata:
          annotations:
            checksum/config: 91cc7f876a48e338c4a6ac9704b9dce35bc96724588f13a96a855588685a9df5
          labels:
            app.kubernetes.io/component: main
            app.kubernetes.io/instance: n8n
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: n8n
            app.kubernetes.io/version: 1.0.0
            helm.sh/chart: n8n-1.0.0
        spec:
          containers:
            - env:
                - name: N8N_HIRING_BANNER_ENABLED
                  value: "false"
                - name: NODE_ENV
                  value: production
                - name: N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS
                  value: "true"
                - name: N8N_PORT
                  value: "5678"
                - name: N8N_DEFAULT_LOCALE
                  value: en
                - name: GENERIC_TIMEZONE
                  value: Europe/Berlin
                - name: N8N_GRACEFUL_SHUTDOWN_TIMEOUT
                  value: "30"
                - name: N8N_MULTI_MAIN_SETUP_ENABLED
                  value: "true"
                - name: N8N_RUNNERS_BUILTINS_DENY
                  value: eval,exec,compile,open,input,breakpoint,getattr,object,type,vars,setattr,delattr,hasattr,dir,memoryview,__build_class__,globals,locals
                - name: N8N_RUNNERS_MAX_PAYLOAD
                  value: "1073741824"
                - name: N8N_BLOCK_RUNNER_ENV_ACCESS
                  value: "true"
                - name: N8N_RUNNERS_ALLOW_PROTOTYPE_MUTATION
                  value: "false"
              envFrom:
                - configMapRef:
                    name: n8n-database-configmap
                - configMapRef:
                    name: n8n-logging-configmap
                - configMapRef:
                    name: n8n-diagnostics-configmap
                - configMapRef:
                    name: n8n-version-notifications-configmap
                - configMapRef:
                    name: n8n-public-api-configmap
                - configMapRef:
                    name: n8n-workflow-history-configmap
                - configMapRef:
                    name: n8n-task-broker-configmap
                - configMapRef:
                    name: n8n-metrics-configmap
                - configMapRef:
                    name: n8n-binary-data-configmap
                - secretRef:
                    name: n8n-encryption-key-secret-v2
              image: docker.io/n8nio/n8n:1.0.0
              imagePullPolicy: IfNotPresent
              livenessProbe:
                httpGet:
                  path: /healthz
                  port: http
              name: n8n-main
              ports:
                - containerPort: 5678
                  name: http
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /healthz/readiness
                  port: http
              resources: null
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                privileged: false
                readOnlyRootFilesystem: false
                runAsGroup: 1000
                runAsNonRoot: true
                runAsUser: 1000
              volumeMounts:
                - mountPath: /home/node/.n8n
                  name: node-modules
                  readOnly: false
          securityContext:
            fsGroup: 1000
            fsGroupChangePolicy: OnRootMismatch
          serviceAccountName: n8n
      updateStrategy:
        type: RollingUpdate
      volumeClaimTemplates:
        - metadata:
            name: node-modules
          spec:
            accessModes:
              - ReadWriteOnce
            resources:
              requests:
                storage: 8Gi
